type Query {
  authors: [Author]
  authorById(id: ID!): Author
  books: [Book]
  bookById(id: ID!): Book
}

type Author {
  id: ID!
  name: String!
  bio: String
  books: [Book]
}

type Book {
  id: ID!
  title: String!
  description: String
  author: Author
}

type Mutation {
  createBook(book: BookInput!): Book
} 

input BookInput {
  title: String!
  description: String
  authorId: ID!
}